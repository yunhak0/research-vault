{
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(wc:*)",
      "Bash(chmod:*)",
      "Bash(ls:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/enforce-uv.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}